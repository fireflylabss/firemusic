{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Firemusic",
  "version": "0.3.0",
  "identifier": "com.fireflylabs.firemusic",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../gui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Firemusic",
        "width": 1120,
        "height": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}